{
  "version": "1",
  "guidance_dir": ".guidance",
  "db_path": ".guidance.db",
  "skills_dir": "doc/skills",
  "capabilities_dir": "doc/capabilities",
  "src_dirs": ["src"],
  "providers": {
    "llama": {
      "base_url": "http://localhost:8080",
      "chat_endpoint": "/v1/chat/completions"
    }
  },
  "models": {
    "default": "llama:code:latest",
    "fast": "llama:code:latest",
    "thinking": "llama:code:latest",
    "batch": "llama:code:latest",
    "embed": "llama:embed:latest"
  },
  "embed": {
    "dims": 768,
    "cache_limit": 400
  },
  "test_commands": {
    ".zig": ["zig", "build", "test", "--summary", "all", "--libc", "libc.conf"],
    ".py": ["python", "-m", "pytest", "-v"],
    ".rs": ["cargo", "test", "--workspace"]
  },
  "lint_commands": {
    ".zig": ["zig", "fmt", "--check", "{file}"],
    ".py": ["ruff", "check", "{file}"],
    ".rs": ["cargo", "clippy", "--workspace", "--", "-D", "warnings"]
  },
  "fmt_commands": {
    ".zig": ["zig", "fmt", "{file}"],
    ".py": ["ruff", "format", "{file}"],
    ".rs": ["cargo", "fmt"]
  },
  "comment": "guidance: produces .guidance.db SQLite vector search database and .guidance/ JSON mirror."
}
