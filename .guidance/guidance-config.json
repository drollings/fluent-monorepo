{
  "version": "1",
  "guidance_dir": ".guidance",
  "db_path": ".explain.db",
  "src_dirs": ["src"],
  "providers": {
    "local": {
      "base_url": "http://localhost:11434",
      "chat_endpoint": "/v1/chat/completions"
    },
    "ollama": {
      "base_url": "http://localhost:11434",
      "chat_endpoint": "/api/chat"
    }
  },
  "models": {
    "default": "local:code:latest",
    "fast": "local:code:latest",
    "thinking": "local:code:latest"
  },
  "test_commands": {
    ".zig": ["zig", "build", "test", "--summary", "all"],
    ".py": ["python", "-m", "pytest", "-v"]
  },
  "lint_commands": {
    ".zig": ["zig", "fmt", "--check", "{file}"],
    ".py": ["ruff", "check", "{file}"]
  },
  "fmt_commands": {
    ".zig": ["zig", "fmt", "{file}"],
    ".py": ["ruff", "format", "{file}"]
  },

  "enable_guidance_db": true,
  "guidance_db_path": ".guidance.db",
  "embedding_provider": "ollama",
  "embedding_model": "embed",
  "embedding_dims": 768,

  "comment": "guidance: produces .explain.db SQLite FTS5 index and .guidance/ JSON mirror for NullClaw."
}