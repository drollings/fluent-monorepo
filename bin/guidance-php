#!/usr/bin/env php
<?php

require __DIR__ . '/vendor/autoload.php';

use PhpParser\Error;
use PhpParser\NodeDumper;
use PhpParser\ParserFactory;
use PhpParser\Node;
use PhpParser\NodeTraverser;
use PhpParser\NodeVisitorAbstract;

// ============================================================================
// Constants & Config
// ============================================================================
define('DEFAULT_OLLAMA_URL', 'http://localhost:11434/api/chat');
define('DEFAULT_MODEL', 'code:latest');

// ============================================================================
// Canonical Signer
// ============================================================================
class CanonicalSigner {
    public static function normalizeType(?string $type): string {
        if (!$type) return "void";
        $type = trim($type);
        return $type === "" ? "void" : $type;
    }

    public static function computeHash(string $signature): string {
        return hash('sha256', $signature);
    }

    public static function functionHash(string $name, array $params, ?string $returnType): string {
        $paramStrs = [];
        foreach ($params as $p) {
            $paramStrs[] = $p['name'] . ':' . self::normalizeType($p['type']);
        }
        $sig = sprintf("%s(%s)->%s", $name, implode(',', $paramStrs), self::normalizeType($returnType));
        return self::computeHash($sig);
    }

    public static function classHash(string $name, array $bases): string {
        $sig = sprintf("%s(%s)", $name, implode(',', $bases));
        return self::computeHash($sig);
    }
}

// ============================================================================
// AST Visitor
// ============================================================================
class GuidanceNodeVisitor extends NodeVisitorAbstract {
    public array $members = [];
    public array $patterns = [];

    public function enterNode(Node $node) {
        if ($node instanceof Node\Stmt\Class_) {
            $this->members[] = $this->parseClass($node);
        } elseif ($node instanceof Node\Stmt\Function_) {
            $this->members[] = $this->parseFunction($node);
        }
        return null;
    }

    private function parseClass(Node\Stmt\Class_ $node): array {
        $name = $node->name ? $node->name->toString() : 'AnonymousClass';
        $bases = [];
        if ($node->extends) $bases[] = $node->extends->toString();
        foreach ($node->implements as $impl) {
            $bases[] = $impl->toString();
        }

        $methods = [];
        foreach ($node->getMethods() as $method) {
            $methods[] = $this->parseMethod($method);
        }

        $patterns = [];
        if (str_ends_with($name, 'Factory')) {
            $patterns[] = ["name" => "Factory (GoF)", "type" => "GoF", "ref" => "doc/skills/gof-patterns/SKILL.md#factory"];
        }

        return [
            'name' => $name,
            'type' => 'struct',
            'signature' => "class $name(" . implode(', ', $bases) . ")",
            'line' => $node->getStartLine(),
            'match_hash' => CanonicalSigner::classHash($name, $bases),
            'comment' => $this->getDocComment($node),
            'params' => [],
            'returns' => null,
            'patterns' => $patterns,
            'tags' => [],
            'is_pub' => true,
            'members' => $methods,
            'skills' => [],
            'capabilities' => [],
            'equivalents' => []
        ];
    }

    private function parseFunction(Node\Stmt\Function_ $node): array {
        return $this->buildCallable($node, 'fn_decl', $node->name->toString(), true);
    }

    private function parseMethod(Node\Stmt\ClassMethod $node): array {
        $isPub = $node->isPublic();
        $type = $isPub ? 'method' : 'method_private';
        return $this->buildCallable($node, $type, $node->name->toString(), $isPub);
    }

    private function buildCallable(Node $node, string $type, string $name, bool $isPub): array {
        $params = [];
        $paramStrs = [];
        foreach ($node->getParams() as $param) {
            $pName = '$' . $param->var->name;
            $pType = $param->type ? (string)$param->type : null;
            $pDefault = $param->default ? 'default' : null; // simplified default detection

            $params[] = ['name' => $pName, 'type' => $pType, 'default' => $pDefault];
            $paramStrs[] = ltrim("$pType $pName");
        }

        $returnType = $node->getReturnType();
        $returnTypeStr = $returnType ? (string)$returnType : null;

        $sigPrefix = str_starts_with($type, 'method') ? 'fn' : 'fn';
        $signature = "$sigPrefix $name(" . implode(', ', $paramStrs) . ")" . ($returnTypeStr ? " -> $returnTypeStr" : "");

        $patterns = [];
        if ($name === 'getInstance' && str_starts_with($type, 'method')) {
            $patterns[] = ["name" => "Singleton (GoF)", "type" => "GoF", "ref" => "doc/skills/gof-patterns/SKILL.md#singleton"];
        }

        return [
            'name' => $name,
            'type' => $type,
            'signature' => $signature,
            'line' => $node->getStartLine(),
            'match_hash' => CanonicalSigner::functionHash($name, $params, $returnTypeStr),
            'comment' => $this->getDocComment($node),
            'params' => $params,
            'returns' => CanonicalSigner::normalizeType($returnTypeStr),
            'patterns' => $patterns,
            'tags' => [],
            'is_pub' => $isPub,
            'members' => [],
            'skills' => [],
            'capabilities' => [],
            'equivalents' => []
        ];
    }

    private function getDocComment(Node $node): ?string {
        $doc = $node->getDocComment();
        if (!$doc) return null;
        $text = $doc->getText();
        // Extract just the first line/summary of the docblock
        if (preg_match('/^\/\*\*\s*\n\s*\*\s*([^@\n]+)/m', $text, $matches)) {
            return trim($matches[1]);
        }
        return null;
    }
}

// ============================================================================
// Core Logic
// ============================================================================

function processFile(string $filepath, string $outputDir, bool $infill, bool $regen, bool $debug): bool {
    $srcPath = realpath($filepath);
    if (!$srcPath) return false;

    // Output path resolution
    $projectRoot = getcwd();
    $relativePath = str_replace($projectRoot . '/', '', $srcPath);
    $jsonPath = $outputDir . '/src/' . $relativePath . '.json';

    // Incremental check
    if (file_exists($jsonPath) && filemtime($srcPath) <= filemtime($jsonPath)) {
        return false;
    }

    $code = file_get_contents($srcPath);
    $parser = (new ParserFactory)->create(ParserFactory::PREFER_PHP7);

    try {
        $ast = $parser->parse($code);
    } catch (Error $error) {
        if ($debug) echo "Parse error in $filepath: {$error->getMessage()}\n";
        return false;
    }

    $traverser = new NodeTraverser();
    $visitor = new GuidanceNodeVisitor();
    $traverser->addVisitor($visitor);
    $traverser->traverse($ast);

    // Dependencies scanning
    preg_match_all('/use\s+([^;]+);/', $code, $useMatches);
    $usedBy = array_map('trim', $useMatches[1] ?? []);

    // LLM Infill Hook (Stubbed for Ollama equivalent)
    if ($infill || $regen) {
        foreach ($visitor->members as &$member) {
            if (!$member['comment'] || $regen) {
                // TODO: Call LLM API via curl here using $member['signature']
                // $member['comment'] = callLlm(...);
            }
        }
    }

    $doc = [
        '$schema' => 'http://json-schema.org/draft-07/schema#',
        'meta' => [
            'module' => str_replace('/', '.', dirname($relativePath)),
            'source' => $relativePath,
            'language' => 'php'
        ],
        'comment' => null,
        'detail' => null,
        'keywords' => [],
        'skills' => [],
        'capabilities' => [],
        'hashtags' => [],
        'used_by' => $usedBy,
        'members' => $visitor->members
    ];

    if (!is_dir(dirname($jsonPath))) {
        mkdir(dirname($jsonPath), 0777, true);
    }

    file_put_contents($jsonPath, json_encode($doc, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));

    // Increment MTime by 1 to mark as successfully validated & processed
    touch($jsonPath, time() + 1);

    if ($debug) echo "Generated: $jsonPath\n";
    return true;
}

// ============================================================================
// CLI Entry
// ============================================================================

$opts = getopt('', ['scan:', 'file:', 'output:', 'infill', 'regen', 'debug']);
$command = $argv[1] ?? 'help';

if ($command === 'sync') {
    $outputDir = rtrim($opts['output'] ?? '.guidance', '/');
    $debug = isset($opts['debug']);
    $infill = isset($opts['infill']);
    $regen = isset($opts['regen']);

    $files = [];
    if (isset($opts['file'])) {
        $files[] = $opts['file'];
    } elseif (isset($opts['scan'])) {
        $dir = new RecursiveDirectoryIterator($opts['scan']);
        $ite = new RecursiveIteratorIterator($dir);
        foreach ($ite as $file) {
            if ($file->getExtension() === 'php') {
                $files[] = $file->getPathname();
            }
        }
    }

    $processed = 0;
    foreach ($files as $f) {
        if (processFile($f, $outputDir, $infill, $regen, $debug)) {
            $processed++;
        }
    }
    echo "✓ Synced $processed PHP file(s).\n";
} elseif ($command === 'scrub') {
    // Scrub logic maps across JSON files and clears synthetic comments
    echo "Scrub not fully implemented in this stub, run Python scrubber for multi-language cleanup.\n";
} else {
    echo "Usage: guidance-php sync --scan <dir> --output <dir> [--infill] [--debug]\n";
}
