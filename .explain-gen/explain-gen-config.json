{
  "_comment": "explain-gen model and provider configuration. All Makefile targets read from this file.",
  "version": "1",
  "ollama": {
    "base_url": "http://localhost:11434",
    "chat_endpoint": "/api/chat",
    "tags_endpoint": "/api/tags",
    "timeout_seconds": 30
  },
  "models": {
    "default": "code:latest",
    "fast": "fast:latest",
    "document": "code:latest",
    "infill": "code:latest",
    "diary": "fast:latest"
  },
  "providers": {
    "zig": "explain-gen",
    "python": "explain-gen-py",
    "cpp": "explain-gen-cpp",
    "rust": "explain-gen-rust",
    "go": "explain-gen-go"
  },
  "guidance_dir": ".explain-gen",
  "src_dirs": ["src"],
  "gen": {
    "infill": true,
    "regen": false,
    "max_comment_chars": 200,
    "max_module_comment_chars": 80
  },
  "comment": "explain-gen: produces .explain.db SQLite FTS5 index and .explain-gen/ JSON mirror for NullClaw."
}
