{
  "version": "1",
  "guidance_dir": ".explain-gen",
  "db_path": ".explain.db",
  "src_dirs": ["src"],
  "openai": {
    "base_url": "http://localhost:11434",
    "chat_endpoint": "/v1/chat/completions"
  },
  "models": {
    "default": "fast:latest",
    "fast": "fast:latest",
    "thinking": "code:latest"
  },
  "test_commands": {
    ".zig": ["zig", "build", "test", "--summary", "all"],
    ".py": ["python", "-m", "pytest", "-v"]
  },
  "lint_commands": {
    ".zig": ["zig", "fmt", "--check", "{file}"],
    ".py": ["ruff", "check", "{file}"]
  },
  "fmt_commands": {
    ".zig": ["zig", "fmt", "{file}"],
    ".py": ["ruff", "format", "{file}"]
  },
  "comment": "explain-gen: produces .explain.db SQLite FTS5 index and .explain-gen/ JSON mirror for NullClaw."
}